# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_EUR_MONTHLY=
STRIPE_PRICE_EUR_YEARLY=
STRIPE_PRICE_USD_MONTHLY=
STRIPE_PRICE_USD_YEARLY=
STRIPE_PRICE_MXN_MONTHLY=
STRIPE_PRICE_MXN_YEARLY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# App
NEXT_PUBLIC_APP_URL=https://aliis.app
NEXT_PUBLIC_API_URL=https://api.aliis.app

# Email
RESEND_API_KEY=

# IA
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
GROQ_API_KEY=

# Analytics
NEXT_PUBLIC_GA_ID=

# Push notifications (web-push / VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT=mailto:hola@aliis.app
CRON_SECRET=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Observability — Sentry
# Frontend project DSN (público, OK exponerlo). Override en Vercel si quieres separar dev/prod.
NEXT_PUBLIC_SENTRY_DSN=
# Solo build-time, para subir source maps (opcional pero recomendado en producción)
SENTRY_AUTH_TOKEN=

# Logging level: debug | info | warn | error (default: info in prod, debug in dev)
LOG_LEVEL=info

# Cron sharding — must match the number of /api/aliis/notify/N entries in vercel.json
NOTIFY_CRON_SHARDS=4
