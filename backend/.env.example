# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Anon key — used by the auth middleware to verify user JWTs forwarded by the frontend.
SUPABASE_ANON_KEY=

# AI providers
ANTHROPIC_API_KEY=
# Used by the intent classifier (Gemini Flash via @ai-sdk/google).
# Without this, the classifier silently falls back to "SAFE" — meaning every
# request reaches the main LLM with NO prompt-injection / dose-question filter.
# Required in production.
GOOGLE_AI_API_KEY=

# Server
PORT=3001
FRONTEND_URL=https://aliis.app

# Observability — Sentry
# Backend project DSN (server-side, never exposed to the browser).
SENTRY_DSN=
